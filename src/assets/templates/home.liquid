{% layout 'layout' %}
{% block %}
<div class="animate-slide-up space-y-6">
  <section class="rounded-2xl border border-indigo-500/20 bg-white dark:bg-zinc-900/80 p-6">
    <span class="mb-2 inline-block text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Welcome</span>
    <h2 class="m-0 text-lg font-semibold">git-on-cloudflare</h2>
    <p class="muted mt-1 mb-0">A Git Smart HTTP v2 server running entirely on Cloudflare Workers.</p>
  </section>
  <div class="space-y-4">
    <div class="card p-6">
      <span class="mb-2 inline-block text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Quick Start</span>
      <h3 class="flex items-center gap-2">
        <i class="bi bi-rocket-takeoff inline w-4 h-4 text-indigo-500" aria-hidden="true"></i>
        Get Started
      </h3>
      <ul class="list space-y-2">
        <li>
          <a
            href="https://git-on-cloudflare.com/rachel/git-on-cloudflare"
            target="_blank"
            rel="noopener"
            >Quickstart</a
          >
        </li>
        <li>
          <a href="/auth">Manage Auth</a>
        </li>
      </ul>
    </div>
  </div>
</div>
{% endblock %}
