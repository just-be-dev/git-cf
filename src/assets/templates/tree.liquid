{% layout 'layout' %}
{% block %}
{% render 'repo_nav', owner: owner, repo: repo, refEnc: refEnc, currentTab: 'browse' %}
{% render 'progress', progress: progress %}
<div class="animate-slide-up">
<span class="mb-1 inline-block text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Browse</span>
<h2>Tree</h2>
{% if breadcrumbs %}
  <nav class="breadcrumb">
    {% if parentHref %}
      <a
        href="{{ parentHref }}"
        class="text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200"
        >..</a
      >
      <span class="text-zinc-400 dark:text-zinc-600">/</span>
    {% endif %}
    {% for crumb in breadcrumbs %}
      {% if crumb.href %}
        <a href="{{ crumb.href }}">{{ crumb.name }}</a>
        {% unless forloop.last %} / {% endunless %}
      {% else %}
        <strong>{{ crumb.name }}</strong>
      {% endif %}
    {% endfor %}
  </nav>
{% endif %}
<table class="mt-4 rounded-2xl overflow-hidden shadow-xs border border-zinc-200 dark:border-zinc-800/60">
  <thead>
    <tr>
      <th>Name</th>
      <th>OID</th>
    </tr>
  </thead>
  <tbody>
    {% if entries and entries.size > 0 %}
      {% for entry in entries %}
        <tr>
          <td>
            <i
              class="{{ entry.iconClass }} inline-block mr-1.5 align-[-2px] {% if entry.isDir %}text-amber-600 dark:text-amber-400{% else %}text-zinc-500 dark:text-zinc-400{% endif %}"
              aria-hidden="true"
            ></i>
            <a href="{{ entry.href }}">{{ entry.name }}</a>
          </td>
          <td class="muted">{{ entry.shortOid }}</td>
        </tr>
      {% endfor %}
    {% else %}
      <tr>
        <td colspan="2">
          <div class="flex flex-col items-center gap-2 py-6 text-center">
            <span class="inline-grid h-10 w-10 place-items-center rounded-full bg-zinc-100 dark:bg-zinc-800/60">
              <i class="bi bi-folder text-zinc-400 dark:text-zinc-600" style="font-size: 1.25rem" aria-hidden="true"></i>
            </span>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">This tree is empty</p>
          </div>
        </td>
      </tr>
    {% endif %}
  </tbody>
</table>
</div>
{% endblock %}
