{% layout 'layout' %}
{% block %}
{% render 'repo_nav', owner: owner, repo: repo, refEnc: refEnc, showRefDropdown: false %}
{% render 'progress', progress: progress %}
<div class="space-y-6 animate-slide-up">
  <section class="rounded-2xl border border-indigo-500/20 bg-white dark:bg-zinc-900/80 p-6">
    <span class="mb-2 inline-block text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Repository</span>
    <h2 class="m-0">Overview</h2>
    <p class="muted mt-1 mb-0">
      Default branch: <code>{{ refShort }}</code>
    </p>
  </section>
  <div class="repo-grid">
    <div class="card p-5">
      <span class="mb-1 inline-block text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Refs</span>
      <h3 class="flex items-center gap-2">
        <i class="bi bi-git inline w-4 h-4 text-indigo-500" aria-hidden="true"></i>
        Branches
      </h3>
      <div class="list">
        {% if branches and branches.size > 0 %}
          {% for branch in branches %}
            <div>
              <a href="/{{ owner }}/{{ repo }}/tree?ref={{ branch.name }}">
                {{- branch.displayName -}}
              </a>
            </div>
          {% endfor %}
        {% else %}
          <div class="flex flex-col items-center gap-2 py-6 text-center">
            <span class="inline-grid h-10 w-10 place-items-center rounded-full bg-zinc-100 dark:bg-zinc-800/60">
              <i class="bi bi-git text-zinc-400 dark:text-zinc-600" style="font-size: 1.25rem" aria-hidden="true"></i>
            </span>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">No branches yet</p>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="card p-5">
      <span class="mb-1 inline-block text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Refs</span>
      <h3 class="flex items-center gap-2">
        <i class="bi bi-tag-fill inline w-4 h-4 text-indigo-500" aria-hidden="true"></i>
        Tags
      </h3>
      <div class="list">
        {% if tags and tags.size > 0 %}
          {% for tag in tags %}
            <div>
              <a href="/{{ owner }}/{{ repo }}/tree?ref={{ tag.name }}">{{ tag.displayName }}</a>
            </div>
          {% endfor %}
        {% else %}
          <div class="flex flex-col items-center gap-2 py-6 text-center">
            <span class="inline-grid h-10 w-10 place-items-center rounded-full bg-zinc-100 dark:bg-zinc-800/60">
              <i class="bi bi-tag-fill text-zinc-400 dark:text-zinc-600" style="font-size: 1.25rem" aria-hidden="true"></i>
            </span>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">No tags yet</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
  {% if readmeMd %}
    <div class="mt-8 border border-zinc-200 dark:border-zinc-800/60 rounded-2xl p-6 bg-white dark:bg-zinc-900/50 markdown-content">
      <div
        data-markdown="1"
        data-md-owner="{{ owner }}"
        data-md-repo="{{ repo }}"
        data-md-ref="{{ refShort }}"
        data-md-base=""
      >
        <pre class="md-src">{{ readmeMd }}</pre>
      </div>
    </div>
  {% endif %}
</div>
{% endblock %}
