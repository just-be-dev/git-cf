{% layout 'layout' %}
{% block %}
<div class="flex flex-col items-center justify-center gap-4 py-16 text-center animate-slide-up">
  <span class="inline-grid h-16 w-16 place-items-center rounded-full bg-zinc-100 dark:bg-zinc-800/60">
    <i class="bi bi-question-circle text-zinc-400 dark:text-zinc-600" style="font-size: 2rem" aria-hidden="true"></i>
  </span>
  <div>
    <span class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">404</span>
    <h1 class="text-xl font-semibold mb-2">Not Found</h1>
    <p class="text-sm text-zinc-500 dark:text-zinc-400">The page you are looking for doesn't exist.</p>
  </div>
  <a class="btn" href="/">Go home</a>
</div>
{% endblock %}
