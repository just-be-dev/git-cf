{% layout 'layout' %}
{% block %}
<div class="animate-slide-up">
  <header class="page-header">
    <div>
      <span class="mb-1 inline-block text-xs font-semibold uppercase tracking-wider text-indigo-500 dark:text-indigo-400">Owner</span>
      <div class="font-semibold text-lg">{{ owner }}</div>
    </div>
    <div></div>
  </header>
  <h2>Repositories</h2>
  <div class="repo-grid">
    {% if repos and repos.size > 0 %}
      {% for r in repos %}
        <a
          href="/{{ owner }}/{{ r }}"
          class="group block card p-5 hover:border-indigo-500/30 dark:hover:border-indigo-500/30 hover:shadow-md transition-all"
        >
          <div class="flex items-center gap-3">
            <span class="inline-grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/20 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors">
              <i class="bi bi-journal-code" style="font-size: 1.1rem" aria-hidden="true"></i>
            </span>
            <div class="text-lg font-medium">
              <span class="text-zinc-500 dark:text-zinc-400">{{ owner }}</span><span class="text-zinc-300 dark:text-zinc-600">/</span><span class="group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors">{{ r }}</span>
            </div>
          </div>
        </a>
      {% endfor %}
    {% else %}
      <div class="col-span-full flex flex-col items-center gap-3 py-10 text-center">
        <span class="inline-grid h-14 w-14 place-items-center rounded-full bg-zinc-100 dark:bg-zinc-800/60">
          <i class="bi bi-journal-code text-zinc-400 dark:text-zinc-600" style="font-size: 1.75rem" aria-hidden="true"></i>
        </span>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">No repositories yet</p>
        <p class="text-xs text-zinc-400 dark:text-zinc-500">Push a repository to get started.</p>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
